# MongoDB connection URI for the backend API
MONGODB_URI=

# JWT secret used to sign authentication tokens
JWT_SECRET=

# Optional JWT expiration timeframe (defaults to 30d)
JWT_EXPIRE=30d

# Optional frontend URL used for CORS and sitemap generation
FRONTEND_URL=https://locksmithajman.com

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=https://locksmithajman.com

# Optional admin bootstrap credentials (only used when no admin exists)
ADMIN_EMAIL=admin@kurtuba.com
ADMIN_PASSWORD=Admin@123456

# Optional site URL for backend-generated sitemap and robots
SITE_URL=https://locksmithajman.com

# Optional backend port override
PORT=5000
